---
import SimpleLayout from '../layouts/SimpleLayout.astro';

const links = [
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/jakubpolec',
    count: '30K+',
    detail: 'followers',
    icon: 'linkedin',
  },
  {
    label: 'X / Twitter',
    href: 'https://twitter.com/jakubpolec',
    count: '3.5K+',
    detail: 'followers',
    icon: 'x',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/jpolec',
    count: '350+',
    detail: 'followers',
    icon: 'github',
  },
  {
    label: 'Medium',
    href: 'https://medium.com/@jpolec_72972',
    count: '1.25K+',
    detail: 'followers',
    icon: 'medium',
  },
  {
    label: 'Substack',
    href: 'https://quantjourney.substack.com',
    count: '7.2K+',
    detail: 'subscribers',
    icon: 'substack',
  },
];
---

<SimpleLayout
  title="Jakub Polec"
  description="Jakub Polec - physicist, founder of QuantJourney, and quantitative infrastructure builder."
>
  <main class="page-shell">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-bg" aria-hidden="true"></div>

      <div class="hero-image-wrap animate-in">
        <img
          src="/jpbg.jpeg"
          alt="Jakub Polec"
          class="hero-image"
          width="440"
          height="550"
          loading="eager"
          decoding="async"
        />
      </div>

      <div class="hero-copy">
        <p class="eyebrow animate-in">Physicist, builder, and curious about how things work.</p>
        <h1 id="hero-title" class="animate-in">Jakub Polec</h1>
        <p class="lead animate-in">
          I build things around quantitative finance, research infrastructure,
          and AI — usually where the interesting problems are too messy for a
          polished demo.
        </p>

        <a
          href="https://quantjourney.cloud"
          class="quantjourney-link animate-in"
          target="_blank"
          rel="noopener"
        >
          QuantJourney <span aria-hidden="true">↗</span>
        </a>

        <div class="action-row animate-in" aria-label="Primary links">
          <a
            href="https://calendar.notion.so/meet/jakubpolec/1-on-1"
            class="button primary"
            target="_blank"
            rel="noopener"
          >
            Set up meeting
          </a>
        </div>
      </div>
    </section>

    <section class="summary animate-in" aria-label="Short profile">
      <p>
        I live in Dubai, UAE, and I am the founder of QuantJourney. I work on
        research infrastructure, systematic trading, and tools for people who
        need to make better decisions with imperfect information.
      </p>
      <p>
        My background is a slightly unusual mix of physics, technology, and
        business. I have worked with Microsoft, Oracle, Orange, T-Mobile,
        organisations in the Middle East, and research teams connected to CERN.
      </p>
    </section>

    <section class="thinking animate-in" aria-labelledby="thinking-title">
      <div>
        <h2 id="thinking-title">What I am thinking about</h2>
      </div>
      <div class="thinking-copy">
        <p>
          AI is becoming cheap and plentiful. The hard part is moving from an
          answer to a useful decision: asking a worthwhile question, using data
          you can actually trust, and building a workflow that survives contact
          with reality.
        </p>
        <p>
          In finance, the model is only one piece of the system. The less visible
          parts — data lineage, validation, execution, risk, and knowing when to
          do nothing — usually decide whether the result is useful. The same
          applies to most serious software.
        </p>
      </div>
    </section>

    <section class="links-section animate-in" aria-labelledby="links-title">
      <h2 id="links-title">Writing, projects, and occasional market thoughts</h2>
      <div class="links-grid">
        {links.map((link) => (
          <a
            href={link.href}
            class="link-item"
            target="_blank"
            rel="noopener"
          >
            <div class="link-icon-wrap">
              {link.icon === 'linkedin' && (
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  role="img"
                  aria-label="LinkedIn"
                >
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  />
                </svg>
              )}
              {link.icon === 'x' && (
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  role="img"
                  aria-label="X / Twitter"
                >
                  <path
                    d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                  />
                </svg>
              )}
              {link.icon === 'github' && (
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  role="img"
                  aria-label="GitHub"
                >
                  <path
                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                  />
                </svg>
              )}
              {link.icon === 'substack' && (
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  role="img"
                  aria-label="Substack"
                >
                  <path
                    d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"
                  />
                </svg>
              )}
              {link.icon === 'medium' && (
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  role="img"
                  aria-label="Medium"
                >
                  <path
                    d="M0 0v24h24V0H0zm19.938 5.686L18.651 6.92a.376.376 0 00-.143.362v9.067a.376.376 0 00.143.361l1.257 1.234v.271h-6.323v-.271l1.303-1.265c.128-.128.128-.165.128-.36V8.99l-3.62 9.195h-.49L6.69 8.99v6.163a.85.85 0 00.233.707l1.694 2.054v.271H3.815v-.27l1.694-2.055a.82.82 0 00.218-.707V8.026a.623.623 0 00-.203-.514L4.025 5.686v-.27h4.574l3.536 7.76 3.11-7.76h4.693v.27z"
                  />
                </svg>
              )}
            </div>
            <div class="link-text">
              <span class="link-label">{link.label}</span>
              <span class="link-count">{link.count}</span>
              <span class="link-detail">{link.detail}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</SimpleLayout>

<script>
  // Scroll-triggered fade-in animations
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.animate-in').forEach((el) =>
      observer.observe(el)
    );
  } else {
    document
      .querySelectorAll('.animate-in')
      .forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  .page-shell {
    width: min(1080px, calc(100% - 40px));
    margin: 0 auto;
    padding: 42px 0 56px;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(280px, 440px) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    min-height: auto;
    padding: 28px 0 24px;
  }

  .hero-bg {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-image-wrap {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: 0 22px 80px rgba(0, 0, 0, 0.34);
    transition: box-shadow 300ms ease;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 620px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 22px;
    color: var(--ink);
    font-size: clamp(2.35rem, 5vw, 4.4rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .lead {
    max-width: 560px;
    margin-bottom: 28px;
    color: var(--muted);
    font-size: clamp(0.98rem, 1.45vw, 1.12rem);
    line-height: 1.58;
  }

  .quantjourney-link {
    display: inline-block;
    margin: -10px 0 26px;
    color: var(--ink);
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition: border-color 160ms ease, color 160ms ease;
  }

  .quantjourney-link:hover {
    color: var(--muted);
    border-color: var(--muted);
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 8px;
    padding: 13px 18px;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.1;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease,
      transform 150ms ease, box-shadow 160ms ease;
  }

  .button:hover {
    background: var(--ink);
    color: var(--page-bg);
    border-color: var(--ink);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.16);
  }

  .button:active {
    transform: translateY(0);
  }

  .button.primary {
    background: transparent;
    color: var(--ink);
  }

  .button.primary:hover {
    background: var(--ink);
    color: var(--page-bg);
    border-color: var(--ink);
  }

  /* ── Summary ── */
  .summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(20px, 4vw, 42px);
    row-gap: 10px;
    padding: 14px 0 18px;
  }

  .summary p {
    margin-bottom: 0;
    color: var(--ink);
    font-size: clamp(0.94rem, 1.18vw, 1rem);
    line-height: 1.58;
  }

  .thinking {
    display: grid;
    grid-template-columns: minmax(190px, 0.7fr) minmax(0, 1.3fr);
    gap: clamp(24px, 6vw, 90px);
    margin-top: 46px;
    padding: 34px 0 8px;
    border-top: 1px solid var(--line);
  }

  .section-kicker {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .thinking h2 {
    max-width: 260px;
    margin: 0;
    color: var(--ink);
    font-size: clamp(1.55rem, 2.6vw, 2.2rem);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.025em;
  }

  .thinking-copy {
    max-width: 650px;
  }

  .thinking-copy p {
    margin: 0 0 14px;
    color: var(--muted);
    font-size: clamp(0.94rem, 1.18vw, 1rem);
    line-height: 1.62;
  }

  /* ── Links Section ── */
  .links-section {
    padding: 30px 0 12px;
  }

  .links-section h2 {
    margin-bottom: 18px;
    color: var(--ink);
    max-width: none;
    white-space: nowrap;
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .link-item {
    display: flex;
    min-height: 148px;
    flex-direction: column;
    border: 0;
    border-radius: 8px;
    background: var(--surface);
    padding: 20px;
    text-decoration: none;
    transition: background 200ms ease, transform 200ms ease,
      box-shadow 200ms ease;
    cursor: pointer;
  }

  .link-item:hover {
    background: var(--surface-strong);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.14);
  }

  .link-item:active {
    transform: translateY(-1px);
  }

  .link-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--soft);
    color: var(--ink);
    margin-bottom: 14px;
    transition: background 200ms ease;
  }

  .link-item:hover .link-icon-wrap {
    background: var(--surface-strong);
  }

  .link-text {
    display: flex;
    flex-direction: column;
    margin-top: auto;
  }

  .link-label {
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 6px;
  }

  .link-count {
    color: var(--ink);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .link-detail {
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 860px) {
    .page-shell {
      width: min(100% - 28px, 680px);
      padding-top: 24px;
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 88px;
      padding-bottom: 34px;
    }

    .hero-image-wrap {
      max-width: 420px;
    }

    .hero-bg {
      width: 400px;
      height: 400px;
      top: -10%;
      right: -20%;
    }

    .summary,
    .links-grid,
    .thinking {
      grid-template-columns: 1fr;
    }

    .thinking {
      gap: 18px;
    }

    .thinking h2 {
      max-width: none;
    }

    .links-section h2 {
      white-space: normal;
    }

    .link-item {
      min-height: 112px;
    }

    .links-grid .link-item {
      flex-direction: row;
      align-items: center;
      gap: 16px;
      min-height: 80px;
    }

    .link-icon-wrap {
      margin-bottom: 0;
    }

    .link-text {
      margin-top: 0;
    }
  }

  @media (max-width: 520px) {
    .action-row,
    .button {
      width: 100%;
    }

    .button {
      padding-right: 14px;
      padding-left: 14px;
    }

    .summary {
      padding: 32px 0;
    }

    .links-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .links-grid .link-item {
      min-height: 72px;
      padding: 14px;
    }
  }
</style>
