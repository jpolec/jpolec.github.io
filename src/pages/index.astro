---
import SimpleLayout from '../layouts/SimpleLayout.astro';

const links = [
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/jakubpolec',
    count: '27K+',
    detail: 'followers',
  },
  {
    label: 'X / Twitter',
    href: 'https://twitter.com/jakubpolec',
    count: '3.5K+',
    detail: 'followers',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/jpolec',
    count: '350+',
    detail: 'followers',
  },
  {
    label: 'Substack',
    href: 'https://quantjourney.substack.com',
    count: '7.2K+',
    detail: 'subscribers',
  },
  {
    label: 'Medium',
    href: 'https://medium.com/@jpolec_72972',
    count: '1.25K+',
    detail: 'followers',
  },
];
---

<SimpleLayout
  title="Jakub Polec"
  description="Jakub Polec - physicist, founder of QuantJourney, and quantitative infrastructure builder."
>
  <main class="page-shell">
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-image-wrap">
        <img src="/jpbg.jpeg" alt="Jakub Polec" class="hero-image" />
      </div>

      <div class="hero-copy">
        <p class="eyebrow">Physicist. Builder. Quant infrastructure.</p>
        <h1 id="hero-title">Jakub Polec</h1>
        <p class="lead">
          I build systems at the intersection of quantitative finance, AI infrastructure,
          and practical technology strategy.
        </p>

        <div class="action-row" aria-label="Primary links">
          <a href="https://calendar.notion.so/meet/jakubpolec/1-on-1" class="button primary" target="_blank" rel="noopener">
            Set up meeting
          </a>
        </div>
      </div>
    </section>

    <section class="summary" aria-label="Short profile">
      <p>
        Founder of QuantJourney. I work on research infrastructure, strategy
        development, and AI-assisted quantitative workflows for professional investors.
      </p>
      <p>
        My earlier work includes technology and innovation roles with Microsoft, Oracle,
        Orange, T-Mobile, public-sector organizations in the Middle East, and research
        work connected to CERN.
      </p>
      <p>
        At Microsoft, my work received worldwide recognition for marketing. I also built
        several startups, including teams recognized by Aulery and CEE Awards.
      </p>
      <p>
        I have contributed as a management expert in think-tank environments. I value
        creativity, clarity, and turning complex ideas into useful systems.
      </p>
    </section>

    <section class="links-section" aria-labelledby="links-title">
      <h2 id="links-title">Links</h2>
      <div class="links-grid">
        {links.map((link) => (
          <a href={link.href} class="link-item" target="_blank" rel="noopener">
            <span class="link-label">{link.label}</span>
            <span class="link-count">{link.count}</span>
            <span class="link-detail">{link.detail}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</SimpleLayout>

<style>
  .page-shell {
    width: min(1080px, calc(100% - 40px));
    margin: 0 auto;
    padding: 42px 0 56px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(280px, 440px) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    min-height: min(720px, calc(100vh - 84px));
    padding: 24px 0 38px;
  }

  .hero-image-wrap {
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: 0 22px 80px rgba(0, 0, 0, 0.34);
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .hero-copy {
    max-width: 620px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--ink);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 22px;
    color: var(--ink);
    font-size: clamp(2.6rem, 6vw, 5.6rem);
    font-weight: 600;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .lead {
    max-width: 580px;
    margin-bottom: 28px;
    color: var(--muted);
    font-size: clamp(1rem, 1.7vw, 1.25rem);
    line-height: 1.5;
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 6px;
    padding: 13px 18px;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.1;
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
  }

  .button:hover {
    background: var(--ink);
    color: var(--page-bg);
    border-color: var(--ink);
  }

  .button.primary {
    background: transparent;
    color: var(--ink);
  }

  .button.primary:hover {
    background: var(--ink);
    color: var(--page-bg);
    border-color: var(--ink);
  }

  .summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(20px, 4vw, 42px);
    row-gap: 10px;
    padding: 14px 0 18px;
  }

  .summary p {
    margin-bottom: 0;
    color: var(--ink);
    font-size: clamp(0.96rem, 1.35vw, 1.08rem);
    line-height: 1.42;
  }

  .links-section {
    padding: 54px 0 20px;
  }

  .links-section h2 {
    margin-bottom: 18px;
    color: var(--ink);
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .link-item {
    display: flex;
    min-height: 138px;
    flex-direction: column;
    justify-content: space-between;
    border: 0;
    border-radius: 6px;
    background: var(--surface);
    padding: 18px;
    text-decoration: none;
  }

  .link-label {
    color: var(--ink);
    font-size: 0.96rem;
    font-weight: 600;
  }

  .link-count {
    margin-top: auto;
    color: var(--ink);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    font-weight: 600;
    line-height: 1;
  }

  .link-detail {
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  @media (max-width: 860px) {
    .page-shell {
      width: min(100% - 28px, 680px);
      padding-top: 24px;
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-bottom: 34px;
    }

    .hero-image-wrap {
      max-width: 420px;
    }

    .summary,
    .links-grid {
      grid-template-columns: 1fr;
    }

    .link-item {
      min-height: 112px;
    }

  }

  @media (max-width: 520px) {
    .action-row,
    .button {
      width: 100%;
    }

    .button {
      padding-right: 14px;
      padding-left: 14px;
    }

    .summary {
      padding: 32px 0;
    }

  }
</style>
