---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Jakub Polec - physicist, technology entrepreneur, and quantitative finance builder.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jakubpolec.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://jakubpolec.com/jpbg.jpeg" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://jakubpolec.com" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://jakubpolec.com/jpbg.jpeg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Light theme (default) ── */
  :root {
    --page-bg: #faf9f7;
    --surface: #fffdf9;
    --surface-strong: #eee8df;
    --ink: #071324;
    --muted: #071324;
    --line: #d8d0c5;
    --accent: #0d6efd;
    --accent-ink: #ffffff;
    --soft: #eee8df;
    --glow: rgba(184, 111, 68, 0.08);
  }

  html {
    background: var(--page-bg);
    color: var(--ink);
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    scroll-behavior: smooth;
    transition: background 300ms ease, color 300ms ease;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--page-bg);
    transition: background 300ms ease, color 300ms ease;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ── Scroll-triggered animations ── */
  @media (prefers-reduced-motion: no-preference) {
    .animate-in {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .animate-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Staggered delays */
    .animate-in:nth-child(2) { transition-delay: 80ms; }
    .animate-in:nth-child(3) { transition-delay: 160ms; }
    .animate-in:nth-child(4) { transition-delay: 240ms; }
    .animate-in:nth-child(5) { transition-delay: 320ms; }
  }

  /* ── Selection ── */
  ::selection {
    background: var(--accent);
    color: var(--accent-ink);
  }

  /* ── Focus visible ── */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
